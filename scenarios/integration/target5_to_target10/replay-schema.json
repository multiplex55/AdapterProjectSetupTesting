{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/replay-scenario.json",
  "title": "ReplayScenario",
  "type": "object",
  "required": ["scenario", "profile", "protocol_version", "events", "expected"],
  "properties": {
    "scenario": {
      "type": "object",
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string", "enum": ["windows-target5-sim"] },
        "target": { "type": "string", "enum": ["windows-target10-sim"] }
      },
      "additionalProperties": false
    },
    "protocol_version": {
      "type": "object",
      "required": ["family", "major", "minor"],
      "properties": {
        "family": { "type": "string", "enum": ["target5-target10-loopback"] },
        "major": { "type": "integer", "minimum": 1 },
        "minor": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["timestamp_ms", "kind", "payload"],
        "properties": {
          "timestamp_ms": { "type": "integer", "minimum": 0 },
          "kind": {
            "type": "string",
            "enum": ["target5_status", "target10_command"]
          },
          "payload": { "type": "object" }
        },
        "additionalProperties": false
      }
    },
    "expected": {
      "type": "object",
      "required": ["outputs", "final_state"],
      "properties": {
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "payload"],
            "properties": {
              "kind": { "type": "string", "enum": ["target10_command"] },
              "payload": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "final_state": {
          "type": "object",
          "required": ["last_target5_sequence", "commands_emitted"],
          "properties": {
            "last_target5_sequence": { "type": "integer", "minimum": 0 },
            "commands_emitted": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
